{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/adapter.js sessionStart"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/before-shell.js"
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/after-file-edit.js"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "node .cursor/hooks/before-submit-prompt.js"
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/adapter.js stop"
      }
    ]
  }
}
